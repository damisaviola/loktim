generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Company {
  id       String  @id @default(cuid())
  name     String
  location String
  logoUrl  String?
  email    String?
  about    String?
  jobs     Job[]
}

model Job {
  id           String   @id @default(cuid())
  title        String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  type         String
  category     String
  education    String
  experience   String
  gender       String
  ageRange     String
  salaryMin    Int?
  salaryMax    Int?
  isPremium    Boolean  @default(false)
  status       String?  @default("pending")
  postedAt     DateTime @default(now())
  description  String
  requirements String[]
  contactUrl   String
  contacts     Json?
  imageUrl     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deadline     DateTime?
  reports      JobReport[]
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobReport {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reason    String
  details   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
