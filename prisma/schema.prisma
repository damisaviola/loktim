generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
}

model Company {
  id       String  @id @default(cuid())
  name     String
  location String
  logoUrl  String?
  email    String?
  jobs     Job[]
}

model Job {
  id           String   @id @default(cuid())
  title        String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  type         String
  category     String
  education    String
  experience   String
  gender       String
  ageRange     String
  salaryMin    Int?
  salaryMax    Int?
  isPremium    Boolean  @default(false)
  status       String?  @default("pending")
  postedAt     DateTime @default(now())
  description  String
  requirements String[]
  contactUrl   String
  contacts     Json?
  imageUrl     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
